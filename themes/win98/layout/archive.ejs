<%
  var archivePosts = site.posts.sort('date', 'desc');
  var postCount = archivePosts.length;
  var archiveYears = [];
  var currentYearGroup = null;

  archivePosts.each(function(post) {
    var yearKey = date(post.date, 'YYYY');

    if (!currentYearGroup || currentYearGroup.key !== yearKey) {
      currentYearGroup = {
        key: yearKey,
        label: yearKey,
        posts: []
      };
      archiveYears.push(currentYearGroup);
    }

    currentYearGroup.posts.push(post);
  });
%>
<div class="archive-list-container" id="content-main" data-status-type="archive" data-post-count="<%= postCount %>">
    <h1>存档</h1>
    <hr>
    <div class="archive-workspace">
      <aside class="archive-tree-pane">
        <ul class="tree-view archive-tree">
          <% archiveYears.forEach(function(group) { %>
            <li>
              <details open>
                <summary><%= group.label %></summary>
                <ul>
                  <% group.posts.forEach(function(post) { %>
                    <li>
                      <a class="archive-post-link no-window" href="<%- url_for(post.path) %>" data-archive-title="<%= post.title %>">
                        <span class="archive-post-date"><%- date(post.date, config.date_format || 'YYYY-MM-DD') %></span>
                        <span class="archive-post-separator">»</span>
                        <span class="archive-post-title"><%= post.title %></span>
                      </a>
                    </li>
                  <% }); %>
                </ul>
              </details>
            </li>
          <% }); %>
        </ul>
      </aside>

      <section class="archive-editor-pane" aria-label="文章阅读区">
        <menu role="tablist" class="multirows archive-tab-list" aria-label="打开的文章"></menu>
        <div class="window archive-tab-panel" role="tabpanel">
          <div class="window-body archive-tab-body">
            <p class="archive-empty-message">从左侧树状列表选择文章。</p>
          </div>
        </div>
      </section>
    </div>
</div>
