<%
  var pageStatusType = page.status_type || page.statusType || (page.path && page.path.indexOf('guestbook/') === 0 ? 'guestbook' : '');
%>
<article class="page-container" id="content-main"<% if (page.title) { %> data-window-title="<%- page.title %>"<% } %><% if (pageStatusType) { %> data-status-type="<%- pageStatusType %>"<% } %>>
    <% if (page.title && page.title.length > 0) { %>
        <h1><%- page.title %></h1>
        <hr>
    <% } %>
    <div class="page-body">
        <%- page.content %>
    </div>

    <% if (theme.gitalk && theme.gitalk.enable) { %>
      <div id="gitalk-container-placeholder" class="gitalk-placeholder">
          <div class="progress-indicator segmented" aria-hidden="true">
              <span class="progress-indicator-bar" style="width: 40%;"></span>
          </div>
          <p class="gitalk-placeholder-text">Gitalk 加载中...</p>
      </div>
    <% } %>
</article>
